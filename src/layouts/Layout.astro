---
import Analytics from '@vercel/analytics/astro'
interface Props {
	title: string;
}

const { title } = Astro.props;

---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<meta name="google-site-verification" content="vKQYNFLbWfLCnioI9cIND9mmhEwcM9v-6c-O_JmUjZA" />

		<script 
		is:inline
		async 
		src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2855445820677989"
     	crossorigin="anonymous">
		</script>

		<title>{title}</title>
		<meta name="title" content="Ashel — Cahaya Al-Qur'an Harimu" />
		<meta name="description" content="Generator ayat Qur'an estetik dengan tafsir Kemenag dan audio." />
		<meta name="keywords" content="Al-Quran harian, generator ayat quran, hikmah quran, ashel quran, tafsir kemenag, ngarumi dev" />
		<meta name="author" content="Raihan - Ngarumi Soft" />
		<link rel="canonical" href="https://ashel-quran.vercel.app/" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ashel-quran.vercel.app/" />
		<meta property="og:title" content="Ashel — Cahaya Al-Qur'an Harimu" />
		<meta property="og:description" content="Temukan petunjuk harimu melalui indahnya ayat Al-Qur'an." />
		<meta property="og:image" content="/og-image.png" /> <meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content="Ashel — Cahaya Al-Qur'an Harimu" />
		<meta property="twitter:description" content="Generator ayat Al-Qur'an estetik dengan tafsir Kemenag dan audio." />
		<meta property="twitter:image" content="/og-image.png" />

		</head>
	<body class="bg-[#0f172a] text-slate-200 font-sans selection:bg-gold selection:text-black">
		<slot />
	</body>
</html>